generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum TopicStatus {
  NOT_STARTED
  LEARNING
  NEED_REVISION
  MASTERED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ResourceType {
  YOUTUBE
  WEBSITE
  PDF
  EXERCISE
  ARTICLE
  NOTE
}

enum StudySessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AchievementType {
  FIRST_SESSION
  SEVEN_DAY_STREAK
  THIRTY_DAY_STREAK
  HUNDRED_HOURS
  HUNDRED_TASKS
  FIRST_SUBJECT
  FIRST_GOAL
  FIRST_REVISION
  MASTER_TOPIC
  FIFTY_SESSIONS
}

enum Mood {
  GREAT
  GOOD
  OKAY
  BAD
  AWFUL
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  settings   UserSettings?
  subjects   Subject[]
  tasks      Task[]
  studySessions StudySession[]
  goals      Goal[]
  journals   Journal[]
  achievements UserAchievement[]
  templates  Template[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  focusDuration   Int      @default(25)
  breakDuration   Int      @default(5)
  longBreakDuration Int    @default(15)
  longBreakInterval Int    @default(4)
  dailyGoalMinutes Int     @default(120)
  weeklyGoalDays  Int      @default(5)
  theme           String   @default("system")
  emailNotifications Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Subject {
  id          String   @id @default(cuid())
  userId      String
  name        String
  color       String   @default("#6366f1")
  icon        String   @default("book-open")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[]
  tasks      Task[]

  @@map("subjects")
}

model Category {
  id          String   @id @default(cuid())
  subjectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics  Topic[]

  @@map("categories")
}

model Topic {
  id            String      @id @default(cuid())
  categoryId    String
  name          String
  description   String?
  difficulty    Difficulty  @default(BEGINNER)
  status        TopicStatus @default(NOT_STARTED)
  estimatedMinutes Int?
  tags          String[]
  lastRevision  DateTime?
  nextRevision  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  notes         Note[]
  resources     Resource[]
  attachments   Attachment[]
  revisions     Revision[]
  studySessions StudySession[]
  tasks         Task[]

  @@map("topics")
}

model Task {
  id              String     @id @default(cuid())
  userId          String
  subjectId       String?
  topicId         String?
  title           String
  description     String?
  estimatedMinutes Int?
  priority        TaskPriority @default(MEDIUM)
  status          TaskStatus   @default(PENDING)
  dueDate         DateTime?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model StudySession {
  id         String            @id @default(cuid())
  userId     String
  topicId    String?
  startTime  DateTime
  endTime    DateTime?
  totalMinutes Int?
  notes      String?
  status     StudySessionStatus @default(ACTIVE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@map("study_sessions")
}

model Resource {
  id          String       @id @default(cuid())
  topicId     String
  title       String
  url         String?
  type        ResourceType @default(WEBSITE)
  description String?
  completed   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("resources")
}

model Attachment {
  id        String   @id @default(cuid())
  topicId   String
  name      String
  url       String
  type      String
  size      Int?
  createdAt DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Note {
  id        String   @id @default(cuid())
  topicId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Revision {
  id         String   @id @default(cuid())
  topicId    String
  date       DateTime
  interval   Int?
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("revisions")
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  targetValue Int?
  currentValue Int     @default(0)
  unit        String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model UserAchievement {
  id            String          @id @default(cuid())
  userId        String
  achievement   AchievementType
  unlockedAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievement])
  @@map("user_achievements")
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks   TemplateTask[]

  @@map("templates")
}

model TemplateTask {
  id              String       @id @default(cuid())
  templateId      String
  title           String
  description     String?
  estimatedMinutes Int?
  priority        TaskPriority @default(MEDIUM)
  sortOrder       Int          @default(0)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_tasks")
}

model Journal {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  wins        String?
  struggles   String?
  learned     String?
  plan        String?
  mood        Mood?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("journals")
}
